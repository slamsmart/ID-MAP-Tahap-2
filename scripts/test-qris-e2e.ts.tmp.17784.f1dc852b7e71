/**
 * End-to-End QRIS Payment Simulation
 * Tests complete flow: create QRIS → simulate payment → verify status → check Convex
 */

import { ConvexHttpClient } from "convex/browser";
import { api } from "../convex/_generated/api";

const CONVEX_URL = process.env.NEXT_PUBLIC_CONVEX_URL || "https://fabulous-bison-818.convex.cloud";
const API_BASE = process.env.NEXT_PUBLIC_SITE_URL || "https://idmap-pesisir.vercel.app";

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

async function getFirstProject() {
  console.log(`\n[0/4] Fetching test project from Convex...`);
  const client = new ConvexHttpClient(CONVEX_URL);
  const projects = await client.query(api.projects.list, {});
  if (projects.length === 0) {
    throw new Error("No projects found. Run: npx tsx scripts/seed-test-project.ts");
  }
  const project = projects[0];
  console.log(`✓ Using project: ${project.title}`);
  console.log(`  Project ID: ${project._id}`);
  return project._id;
}

async function createQrisPayment(amount: number, projectId: string) {
  console.log(`\n[1/4] Creating QRIS payment for Rp ${amount.toLocaleString("id-ID")}...`);
  const response = await fetch(`${API_BASE}/api/payment/create-qris`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ amount, projectId }),
  });
  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Failed to create QRIS: ${response.statusText} - ${errorText}`);
  }
  const data = await response.json();
  console.log(`✓ QRIS created`);
  console.log(`  Contribution ID: ${data.contributionId}`);
  console.log(`  Mayar Payment ID: ${data.paymentId}`);
  console.log(`  CO2 Equivalent: ${data.co2Equivalent} tCO2e`);
  console.log(`  Sandbox: ${data.isSandbox}`);
  console.log(`  Dummy: ${data.isDummy}`);
  if (data.qrImageUrl) {
    console.log(`  QR Image URL: ${data.qrImageUrl}`);
  }
  return data;
}

async function simulatePayment(contributionId: string) {
  console.log(`\n[2/4] Simulating payment confirmation...`);
  const response = await fetch(`${API_BASE}/api/payment/simulate`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ contributionId }),
  });
  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Failed to simulate: ${response.statusText} - ${errorText}`);
  }
  const data = await response.json();
  console.log(`✓ Payment simulated`);
  console.log(`  Message: ${data.message}`);
  return data;
}

async function checkPaymentStatus(contributionId: string) {
  console.log(`\n[3/4] Checking payment status via API...`);
  const response = await fetch(`${API_BASE}/api/payment/status?contributionId=${contributionId}`);
  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Failed to check status: ${response.statusText} - ${errorText}`);
  }
  const data = await response.json();
  console.log(`✓ Status retrieved: ${data.paymentStatus}`);
  return data;
}

async function verifyConvexRecord(contributionId: string) {
  console.log(`\n[4/4] Verifying Convex database record...`);
  const client = new ConvexHttpClient(CONVEX_URL);
  const status = await client.query(api.contributions.getStatus, {
    contributionId: contributionId as any,
  });
  if (!status) {
    console.log(`✗ Contribution not found in Convex`);
    return null;
  }
  console.log(`✓ Convex record found`);
  console.log(`  Payment status: ${status.paymentStatus}`);
  return status;
}

async function runE2ETest() {
  console.log("=".repeat(60));
  console.log("QRIS Payment End-to-End Test (Mayar.id)");
  console.log("=".repeat(60));

  try {
    const testAmount = 50000;

    console.log(`\nTest Configuration:`);
    console.log(`  API Base: ${API_BASE}`);
    console.log(`  Convex URL: ${CONVEX_URL}`);
    console.log(`  Amount: Rp ${testAmount.toLocaleString("id-ID")}`);

    const projectId = await getFirstProject();
    const qrisData = await createQrisPayment(testAmount, projectId);

    await sleep(1000);
    await simulatePayment(qrisData.contributionId);
    await sleep(2000);

    const statusData = await checkPaymentStatus(qrisData.contributionId);
    const convexStatus = await verifyConvexRecord(qrisData.contributionId);

    console.log("\n" + "=".repeat(60));
    console.log("Test Results");
    console.log("=".repeat(60));

    const checks = [
      { name: "QRIS Created", pass: !!qrisData.contributionId },
      { name: "QR Image URL Generated", pass: !!qrisData.qrImageUrl },
      { name: "Mayar Live (not dummy)", pass: !qrisData.isDummy },
      { name: "Payment Simulated", pass: true },
      { name: "Status API Returns Paid", pass: statusData.paymentStatus === "paid" },
      { name: "Convex Record Status Paid", pass: convexStatus?.paymentStatus === "paid" },
    ];

    checks.forEach((c) => console.log(`${c.pass ? "✓" : "✗"} ${c.name}`));

    const allPassed = checks.every((c) => c.pass);
    console.log("\n" + "=".repeat(60));
    console.log(allPassed ? "✓ ALL TESTS PASSED" : "✗ SOME TESTS FAILED");
    console.log("=".repeat(60));
    process.exit(allPassed ? 0 : 1);
  } catch (error) {
    console.error("\n✗ Test failed:");
    console.error(error);
    process.exit(1);
  }
}

runE2ETest();
