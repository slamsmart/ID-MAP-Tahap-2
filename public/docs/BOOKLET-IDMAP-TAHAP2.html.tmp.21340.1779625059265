    font-size:7pt; color:var(--s400); }
  .dot { width:5px; height:5px; background:var(--g400); border-radius:50%;
    display:inline-block; margin:0 3px; }

  .small { font-size:8pt; color:var(--s500,#6b7280); }
  .spacer { margin-top:5mm; }

  @media print {
    body { background:white; }
    .page { margin:0; box-shadow:none; }
  }
</style>
