  .tli { display:flex; gap:10px; margin-bottom:5mm; }
  .tld { width:26px; height:26px; flex-shrink:0;
    background:var(--g600); border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-size:8pt; font-weight:700; }
  .tlc { flex:1; padding-top:3px; }
  .tlc h4 { margin:0 0 1px; font-size:9pt; }
  .tlc .tlp { font-size:7.5pt; color:var(--g600); font-weight:600; margin-bottom:2px; }
  .tlc p { font-size:8.5pt; margin:0; color:var(--s600); }

  /* TOC */
  .toc-ch { display:flex; justify-content:space-between; align-items:baseline;
    padding:5px 0 3px; border-bottom:1px solid var(--s300,#cbd5e1);
