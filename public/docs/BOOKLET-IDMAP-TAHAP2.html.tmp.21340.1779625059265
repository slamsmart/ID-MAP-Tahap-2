  .tp { color:var(--g600); font-weight:700; font-size:9pt; }

  /* Separator */
  hr { border:none; border-top:1px solid var(--s200); margin:4mm 0; }

  /* Footer */
  .pf { margin-top:auto; padding-top:4mm; border-top:1px solid var(--s200);
