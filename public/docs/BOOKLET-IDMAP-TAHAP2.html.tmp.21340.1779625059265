  .svc-top p { font-size:8.5pt; color:var(--s600); margin:0; }
  .svc-vals { display:grid; grid-template-columns:repeat(3,1fr);
    border-top:1px solid var(--s200); background:var(--s50); }
  .sv { padding:7px 6px; text-align:center; border-right:1px solid var(--s200); }
  .sv:last-child { border-right:none; }
  .sv .vv { font-size:9pt; font-weight:800; color:var(--g800); }
  .sv .vl { font-size:6.5pt; color:var(--s400); margin-top:1px; }

  /* Timeline */
