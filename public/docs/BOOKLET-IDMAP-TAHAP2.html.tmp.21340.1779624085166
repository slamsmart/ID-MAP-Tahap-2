<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ID-MAP — Booklet Platform Ekosistem Karbon Mangrove Indonesia</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap');

  :root {
    --green-900: #14532d;
    --green-800: #166534;
    --green-700: #15803d;
    --green-600: #16a34a;
    --green-500: #22c55e;
    --green-400: #4ade80;
    --green-100: #dcfce7;
    --green-50:  #f0fdf4;
    --blue-600:  #0284c7;
    --blue-100:  #e0f2fe;
    --amber-600: #d97706;
    --amber-100: #fef3c7;
    --slate-900: #0f172a;
    --slate-800: #1e293b;
    --slate-700: #334155;
    --slate-600: #475569;
    --slate-400: #94a3b8;
    --slate-200: #e2e8f0;
    --slate-100: #f1f5f9;
    --slate-50:  #f8fafc;
    --white: #ffffff;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10pt;
    color: var(--slate-800);
    background: #e5e7eb;
    line-height: 1.6;
  }

  /* ── PAGE SETUP ── */
  .page {
    width: 210mm;
    min-height: 297mm;
    background: var(--white);
    margin: 12mm auto;
    padding: 0;
    box-shadow: 0 4px 24px rgba(0,0,0,.15);
    position: relative;
    overflow: hidden;
    page-break-after: always;
  }

  /* ── COVER PAGE ── */
  .cover {
    background: linear-gradient(145deg, var(--green-900) 0%, var(--green-700) 55%, var(--green-500) 100%);
    min-height: 297mm;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .cover::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 340px; height: 340px;
    border-radius: 50%;
    background: rgba(255,255,255,.06);
  }
  .cover::after {
    content: '';
    position: absolute;
    bottom: -80px; left: -80px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: rgba(255,255,255,.04);
  }
  .cover-top {
    padding: 18mm 18mm 0;
  }
  .cover-badge {
    display: inline-block;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.3);
    color: #fff;
    font-size: 7.5pt;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
  }
  .cover-logo {
    font-family: 'Playfair Display', serif;
    font-size: 52pt;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -1px;
  }
  .cover-logo span {
    color: var(--green-400);
  }
  .cover-tagline {
    font-size: 11pt;
    color: rgba(255,255,255,.82);
    font-weight: 400;
    margin-top: 6px;
    line-height: 1.5;
    max-width: 140mm;
  }
  .cover-mid {
    padding: 0 18mm;
  }
  .cover-title-block {
    border-left: 4px solid var(--green-400);
    padding-left: 14px;
    margin: 10mm 0;
  }
  .cover-title-block h1 {
    font-size: 16pt;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }
  .cover-title-block p {
    font-size: 9pt;
    color: rgba(255,255,255,.7);
    margin-top: 4px;
  }
  .cover-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin: 8mm 0;
  }
  .pillar-card {
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 10px;
    padding: 10px 12px;
    text-align: center;
  }
  .pillar-card .icon { font-size: 16pt; margin-bottom: 4px; }
  .pillar-card .label { font-size: 7.5pt; color: rgba(255,255,255,.85); font-weight: 600; }
  .pillar-card .sub { font-size: 6.5pt; color: rgba(255,255,255,.6); margin-top: 2px; }
  .cover-bottom {
    padding: 8mm 18mm;
    background: rgba(0,0,0,.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cover-meta { color: rgba(255,255,255,.75); font-size: 8pt; }
  .cover-meta strong { color: #fff; display: block; font-size: 9pt; }
  .cover-version {
    background: var(--green-400);
    color: var(--green-900);
    font-weight: 700;
    font-size: 8pt;
    padding: 4px 10px;
    border-radius: 6px;
  }

  /* ── INNER PAGES ── */
  .inner {
    padding: 16mm 18mm;
    min-height: 297mm;
    display: flex;
    flex-direction: column;
  }

  /* Header strip */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--green-500);
    margin-bottom: 12px;
  }
  .page-header .brand {
    font-weight: 800;
    font-size: 9pt;
    color: var(--green-700);
    letter-spacing: 1px;
  }
  .page-header .chapter-label {
    font-size: 7.5pt;
    color: var(--slate-400);
    font-weight: 500;
  }

  /* Chapter title */
  .chapter-title {
    margin-bottom: 8mm;
  }
  .chapter-num {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green-600);
    margin-bottom: 4px;
  }
  .chapter-title h2 {
    font-family: 'Playfair Display', serif;
    font-size: 20pt;
    font-weight: 700;
    color: var(--slate-900);
    line-height: 1.2;
  }
  .chapter-title p {
    font-size: 9.5pt;
    color: var(--slate-600);
    margin-top: 5px;
    line-height: 1.5;
  }

  /* Section heading */
  h3 {
    font-size: 11pt;
    font-weight: 700;
    color: var(--green-800);
    margin: 7mm 0 3mm;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  h3::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 14px;
    background: var(--green-500);
    border-radius: 2px;
    flex-shrink: 0;
  }
  h4 {
    font-size: 9.5pt;
    font-weight: 700;
    color: var(--slate-800);
    margin: 5mm 0 2mm;
  }
  p { margin-bottom: 4mm; font-size: 9.5pt; line-height: 1.65; color: var(--slate-700); }
  ul, ol { padding-left: 16px; margin-bottom: 4mm; }
  li { margin-bottom: 2mm; font-size: 9.5pt; line-height: 1.55; color: var(--slate-700); }
  li strong { color: var(--slate-900); }

  /* Callout boxes */
  .callout {
    border-radius: 10px;
    padding: 10px 14px;
    margin: 4mm 0;
    font-size: 9pt;
  }
  .callout-green {
    background: var(--green-50);
    border-left: 4px solid var(--green-500);
    color: var(--green-900);
  }
  .callout-blue {
    background: var(--blue-100);
    border-left: 4px solid var(--blue-600);
    color: #0c4a6e;
  }
  .callout-amber {
    background: var(--amber-100);
    border-left: 4px solid var(--amber-600);
    color: #78350f;
  }
  .callout strong { font-weight: 700; display: block; margin-bottom: 3px; }

  /* Tables */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 4mm 0;
    font-size: 8.5pt;
  }
  th {
    background: var(--green-800);
    color: #fff;
    font-weight: 600;
    padding: 7px 10px;
    text-align: left;
    font-size: 8pt;
  }
  td {
    padding: 6px 10px;
    border-bottom: 1px solid var(--slate-200);
    color: var(--slate-700);
    vertical-align: top;
  }
  tr:nth-child(even) td { background: var(--slate-50); }
  tr:hover td { background: var(--green-50); }

  /* Stat cards row */
  .stat-row {
    display: grid;
    gap: 8px;
    margin: 4mm 0;
  }
  .stat-row.cols-3 { grid-template-columns: repeat(3, 1fr); }
  .stat-row.cols-4 { grid-template-columns: repeat(4, 1fr); }
  .stat-row.cols-2 { grid-template-columns: repeat(2, 1fr); }
  .stat-card {
    background: var(--slate-50);
    border: 1px solid var(--slate-200);
    border-radius: 10px;
    padding: 10px 12px;
  }
  .stat-card .num {
    font-size: 16pt;
    font-weight: 800;
    color: var(--green-700);
    line-height: 1;
  }
  .stat-card .label { font-size: 7.5pt; color: var(--slate-500); margin-top: 3px; }
  .stat-card .sub { font-size: 7pt; color: var(--slate-400); margin-top: 2px; }

  /* Flow diagram */
  .flow {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin: 4mm 0;
    padding: 10px;
    background: var(--green-50);
    border-radius: 10px;
  }
  .flow-step {
    background: var(--white);
    border: 1.5px solid var(--green-400);
    border-radius: 8px;
    padding: 7px 10px;
    text-align: center;
    font-size: 7.5pt;
    font-weight: 600;
    color: var(--green-800);
    flex: 1;
    min-width: 22mm;
  }
  .flow-step .sub { font-size: 6.5pt; color: var(--slate-500); font-weight: 400; margin-top: 2px; }
  .flow-arrow { color: var(--green-500); font-size: 12pt; font-weight: 700; flex-shrink: 0; }

  /* Badge */
  .badge {
    display: inline-block;
    font-size: 7pt;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  .badge-green { background: var(--green-100); color: var(--green-800); }
  .badge-blue  { background: var(--blue-100);  color: #0369a1; }
  .badge-amber { background: var(--amber-100); color: #92400e; }
  .badge-red   { background: #fee2e2; color: #991b1b; }

  /* Comparison grid */
  .compare-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin: 4mm 0;
  }
  .compare-card {
    border-radius: 10px;
    padding: 10px 12px;
    border: 1px solid var(--slate-200);
  }
  .compare-card.highlight {
    border: 2px solid var(--green-500);
    background: var(--green-50);
  }
  .compare-card .cname {
    font-size: 8pt;
    font-weight: 700;
    color: var(--slate-800);
    margin-bottom: 5px;
  }
  .compare-card ul { padding-left: 12px; }
  .compare-card li { font-size: 7.5pt; color: var(--slate-600); margin-bottom: 2px; }
  .compare-card.highlight .cname { color: var(--green-800); }

  /* Role pill */
  .roles-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin: 3mm 0;
  }
  .role-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--slate-50);
    border: 1px solid var(--slate-200);
    border-radius: 8px;
    padding: 7px 12px;
    font-size: 8pt;
  }
  .role-pill .icon { font-size: 14pt; }
  .role-pill .name { font-weight: 700; color: var(--slate-800); }
  .role-pill .desc { font-size: 7pt; color: var(--slate-500); }

  /* Timeline */
  .timeline { margin: 4mm 0; }
  .tl-item { display: flex; gap: 10px; margin-bottom: 6mm; }
  .tl-dot {
    width: 28px; height: 28px; flex-shrink: 0;
    background: var(--green-600);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: 8pt;
    font-weight: 700;
  }
  .tl-content { flex: 1; padding-top: 4px; }
  .tl-content h4 { margin: 0 0 2px; font-size: 9pt; }
  .tl-content .tl-period { font-size: 7.5pt; color: var(--green-600); font-weight: 600; margin-bottom: 3px; }
  .tl-content p { font-size: 8.5pt; margin: 0; color: var(--slate-600); }

  /* TOC */
  .toc-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 4px 0;
    border-bottom: 1px dotted var(--slate-300);
    font-size: 9.5pt;
  }
  .toc-item.chapter {
    font-weight: 700;
    color: var(--slate-900);
    padding: 6px 0 4px;
    border-bottom: 1px solid var(--slate-300);
    margin-top: 2mm;
  }
  .toc-item.sub { padding-left: 10px; color: var(--slate-600); }
  .toc-page { color: var(--green-600); font-weight: 700; font-size: 9pt; }

  /* Two column */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 3mm 0; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin: 3mm 0; }

  /* Highlight number */
  .big-number {
    font-size: 28pt;
    font-weight: 900;
    color: var(--green-600);
    line-height: 1;
  }

  /* Risk table */
  .risk-low  { color: #16a34a; font-weight: 600; }
  .risk-med  { color: #d97706; font-weight: 600; }
  .risk-high { color: #dc2626; font-weight: 600; }

  /* Separator */
  .sep { border: none; border-top: 1px solid var(--slate-200); margin: 5mm 0; }

  /* Footer */
  .page-footer {
    margin-top: auto;
    padding-top: 5mm;
    border-top: 1px solid var(--slate-200);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 7.5pt;
    color: var(--slate-400);
  }
  .page-footer .dot { width: 6px; height: 6px; background: var(--green-400); border-radius: 50%; display: inline-block; margin: 0 4px; }

  /* Spacer */
  .spacer { margin-top: 6mm; }
  .small { font-size: 8pt; color: var(--slate-500); }

  /* ── PRINT ── */
  @media print {
    body { background: white; }
    .page { margin: 0; box-shadow: none; }
  }
</style>
</head>
